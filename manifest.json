{
  "manifest_version": 3,
  "name": "BackOut",
  "version": "1.0",
  "description": "Closes a tab when Back has nowhere left to go.",
  "permissions": [
    "tabs",
    "storage",
    "windows"
  ],
  "icons": {
    "16": "icon/icon16.png",
    "32": "icon/icon32.png",
    "48": "icon/icon48.png",
    "128": "icon/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icon/icon16.png",
      "32": "icon/icon32.png"
    },
    "default_popup": "popup.html",
    "default_title": "BackOut"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ]
    }
  ]
}